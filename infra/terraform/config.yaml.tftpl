host: ""
port: 8317

tls:
  enable: false

remote-management:
  allow-remote: true
  secret-key: "${management_secret}"
  disable-control-panel: false

auth-dir: "/data/auths"

api-keys:
${api_keys_yaml}

routing:
  strategy: "round-robin"

debug: false
logging-to-file: false
request-retry: 3
max-retry-interval: 30
usage-statistics-enabled: true

quota-exceeded:
  switch-project: true
  switch-preview-model: true
