host: ""
port: 8317

tls:
  enable: false

remote-management:
  allow-remote: true
  secret-key: "${management_secret}"
  disable-control-panel: false

# Auth tokens are stored in the GCS-backed /data/auths directory,
# managed entirely via the management dashboard.
auth-dir: "/data/auths"

# API keys are managed via the management dashboard, not Terraform.
# Add keys at https://llm.proxies.of.achyuth.dev/management.html
api-keys: []

routing:
  strategy: "round-robin"

debug: false
logging-to-file: false
request-retry: 3
max-retry-interval: 30
usage-statistics-enabled: true

quota-exceeded:
  switch-project: true
  switch-preview-model: true
