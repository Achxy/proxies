gcp_project          = "your-gcp-project-id"
gcp_region           = "us-central1"
cloudflare_api_token = "your-cloudflare-api-token"
cloudflare_zone_id   = "your-achyuth-dev-zone-id"
domain               = "llm.proxies.of.achyuth.dev"
database_url         = "postgresql://user:pass@ep-xxx.us-central1.aws.neon.tech/neondb?sslmode=require"
litellm_master_key   = "sk-your-master-key"
litellm_salt_key     = "base64-encoded-salt-from-openssl-rand"
image_tag            = "main-stable"

# CLIProxyAPI
cliproxy_domain              = "models.proxies.of.achyuth.dev"
cliproxy_image_tag           = "v6.9.7"
cliproxy_pgstore_dsn         = "postgresql://user:pass@ep-xxx.us-central1.aws.neon.tech/neondb?sslmode=require"
cliproxy_management_password = "your-management-password"
cliproxy_upstream_key        = "sk-your-cliproxy-api-key"
